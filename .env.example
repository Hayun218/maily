# ── 세션 암호화 (최소 32자 랜덤 문자열) ──────────────────────────
SESSION_SECRET=your-super-secret-key-at-least-32-characters-long

# ── Google OAuth (Gmail) ──────────────────────────────────────────
# Google Cloud Console > API 및 서비스 > 사용자 인증 정보 > OAuth 2.0 클라이언트 ID
# 승인된 리디렉션 URI에 아래 콜백 URL 추가 필요
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-google-client-secret

# 로컬 개발
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/gmail/callback

# Vercel 배포 후에는 아래와 같이 변경
# GOOGLE_REDIRECT_URI=https://your-app.vercel.app/api/auth/gmail/callback
